# --- 本番ドメイン（OGP・共有リンクの絶対URLに使用）---
# Vercel デプロイ後の URL を設定
NEXT_PUBLIC_SITE_URL=https://example.vercel.app

# --- 公式 X（アーキパッド【公式】）---
# 例: https://x.com/archi_pad または https://x.com/archipad_aomori
# NEXT_PUBLIC_OFFICIAL_X_URL=https://x.com/archi_pad
# NEXT_PUBLIC_OFFICIAL_X_HANDLE=archi_pad

# --- Stripe（有料の技術動画・CAD 販売・Checkout）---
# STRIPE_SECRET_KEY=sk_live_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
