# --- 本番ドメイン（OGP・共有リンクの絶対URLに使用）---
# Vercel デプロイ後の URL を設定
NEXT_PUBLIC_SITE_URL=https://example.vercel.app

# --- 公式 X（現場ノート【公式】 / Genba-Note）---
# 例: https://x.com/genba_note または https://x.com/genba_note_aomori
# NEXT_PUBLIC_OFFICIAL_X_URL=https://x.com/genba_note
# NEXT_PUBLIC_OFFICIAL_X_HANDLE=genba_note

# --- Stripe（有料の技術動画・CAD 販売・Checkout）---
# STRIPE_SECRET_KEY=sk_live_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
